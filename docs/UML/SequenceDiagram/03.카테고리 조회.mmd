sequenceDiagram
    autonumber
    actor Admin as 관리자
    participant UI as : ResourceAdminUI
    participant Service as : ResourceAdminService
    participant CatRepo as : CategoryRepository
    participant ResRepo as : ResourceRepository
    participant RsvRepo as : ReservationRepository

    Admin->>UI: '대시보드' 메뉴 클릭 (또는 앱 실행)
    activate UI
    UI->>Service: getCategoryDashboardData()
    activate Service
    
    %% DB 전체 카테고리 조회 요청
    Service->>CatRepo: findAll()
    activate CatRepo

    alt [DB 연결 오류 시 (Extension 2b)]
        CatRepo-->>Service: DB Connection 예외 던짐
        Service-->>UI: 조회 실패 예외 반환
        UI-->>Admin: 경고 메시지 출력 ("데이터를 불러오는 중 오류가 발생했습니다")
        
    else [등록된 카테고리가 없는 경우 (Extension 2a)]
        CatRepo-->>Service: 빈 리스트([]) 반환
        Service-->>UI: 빈 데이터(Empty List) 반환
        UI-->>Admin: Empty State 화면 출력 ("새로운 카테고리를 추가해 주세요")
        
    else [카테고리가 존재하는 경우 (Main Success)]
        CatRepo-->>Service: List<Category> 반환
        deactivate CatRepo
        
        %% 통계 집계를 위한 루프 처리
        loop 각 카테고리 항목별 반복
            Service->>ResRepo: countByCategoryId(categoryId)
            activate ResRepo
            ResRepo-->>Service: 등록 자원 수 반환
            deactivate ResRepo
            
            Service->>RsvRepo: countTodayReservations(categoryId)
            activate RsvRepo
            RsvRepo-->>Service: 오늘 예약 건수 반환
            deactivate RsvRepo
        end
        
        Service-->>UI: 요약 통계 데이터(CategorySummaryDto 리스트) 반환
        deactivate Service
        
        UI->>UI: renderResourceDashboard(data)
        UI-->>Admin: 카테고리 데이터 테이블 화면 출력
        deactivate UI
    end