sequenceDiagram
    autonumber
    actor Admin as 관리자
    participant UI as : UserManagementUI
    participant Modal as : PenaltyModalUI
    participant Service as : UserPenaltyService
    participant UserRepo as : UserRepository
    participant User as : User
    participant Penalty as : Penalty
    participant PenRepo as : PenaltyRepository

    Admin->>UI: '권한 제한(제재 추가)' 버튼 클릭 (userId 전달)
    activate UI
    UI->>Modal: open(userId)
    activate Modal
    Modal-->>Admin: 제재 상세 입력 모달창 렌더링
    
    Admin->>Modal: 제재 사유 및 기간(시작일/종료일) 입력
    Admin->>Modal: '저장' 버튼 클릭 (submit)
    
    %% 1차 검증: UI 계층 (프론트엔드 유효성 검사)
    alt [필수 값 누락 시 (Extension 5a)]
        Modal-->>Admin: 입력 필드 강조 및 경고 ("사유와 기간을 모두 입력해 주세요")
        
    else [날짜 논리 오류 시 (Extension 5b)]
        Modal-->>Admin: 경고 메시지 출력 ("제재 종료일은 시작일 이후여야 합니다")
        
    else [UI 검증 정상 통과 시]
        Modal->>Service: restrictUser(userId, PenaltyDto)
        activate Service
        
        %% 1. 대상 사용자 조회
        Service->>UserRepo: findById(userId)
        activate UserRepo
        
        alt [DB 연결 오류 시 (Extension 5c)]
            UserRepo-->>Service: DB Connection 예외 던짐
            deactivate UserRepo
            Service-->>Modal: 시스템 오류 예외 반환
            Modal-->>Admin: 메시지 출력 ("시스템 오류로 권한 제한 처리에 실패했습니다")
            
        else [정상 처리 시 (Main Success)]
            UserRepo-->>Service: User 객체 반환
            
            %% 2. 사용자 상태 업데이트 (엔티티 내부 상태 변경)
            Service->>User: suspend(PenaltyDto.period)
            activate User
            User-->>Service: 상태 '이용 정지'로 변경 완료
            deactivate User
            
            %% 3. 제재 내역(Penalty) 엔티티 생성 및 영속화
            Service->>Penalty: create(userId, reason, startDate, endDate)
            activate Penalty
            Penalty-->>Service: Penalty 객체 반환
            deactivate Penalty
            
            Service->>PenRepo: save(penalty)
            activate PenRepo
            PenRepo-->>Service: 저장된 Penalty 객체 반환
            deactivate PenRepo
            
            Service-->>Modal: 제재 처리 완료 반환
            deactivate Service
            
            Modal->>Modal: displaySuccess()
            Modal-->>UI: 모달 닫기 및 갱신 알림
            deactivate Modal
            
            UI->>UI: renderUserList()
            UI-->>Admin: 사용자 목록 렌더링 (해당 사용자 '제재 중' 상태 반영)
            deactivate UI
        end
    end