sequenceDiagram
    autonumber
    actor Admin as 관리자
    participant UI as : UserManagementUI
    participant Modal as : PenaltyModalUI
    participant Service as : UserPenaltyService
    participant Repo as : PenaltyRepository
    participant Entity as : Penalty

    Admin->>UI: '제재 수정' 버튼 클릭 (penaltyId 전달)
    activate UI
    UI->>Modal: open(penaltyId, currentData)
    activate Modal
    Modal-->>Admin: 기존 제재 정보가 채워진 수정 팝업 렌더링
    
    Admin->>Modal: 제재 사유 및 기간(종료일 등) 수정
    Admin->>Modal: '저장' 버튼 클릭 (submit)
    
    %% 1차 검증: UI 계층 (프론트엔드 유효성 검사)
    alt [필수 값 누락 시 (Extension 5a)]
        Modal-->>Admin: 입력 필드 강조 및 경고 ("사유와 기간을 모두 입력해 주세요")
        
    else [날짜 논리 오류 시 (Extension 5b)]
        Modal-->>Admin: 경고 메시지 출력 ("제재 종료일은 시작일 이후여야 합니다")
        
    else [UI 검증 정상 통과 시]
        Modal->>Service: updatePenalty(penaltyId, PenaltyDto)
        activate Service
        
        %% 1. 기존 제재 데이터 조회
        Service->>Repo: findById(penaltyId)
        activate Repo
        
        alt [DB 연결 오류 시 (Extension 5c)]
            Repo-->>Service: DB Connection 예외 던짐
            deactivate Repo
            Service-->>Modal: 시스템 오류 예외 반환
            Modal-->>Admin: 메시지 출력 ("시스템 오류로 제재 정보 수정에 실패했습니다")
            
        else [정상 수정 가능 시 (Main Success)]
            Repo-->>Service: Penalty 객체 반환
            
            %% 2. 엔티티 정보 업데이트 (객체 지향적 상태 변경)
            Service->>Entity: update(reason, startDate, endDate)
            activate Entity
            Entity-->>Service: 상태 변경 완료
            deactivate Entity
            
            %% 3. 영속화 및 결과 반환
            Service->>Repo: save(penalty)
            activate Repo
            Repo-->>Service: 저장된 객체 반환
            deactivate Repo
            
            Service-->>Modal: 업데이트 완료 반환
            deactivate Service
            
            Modal->>Modal: displaySuccess()
            Modal-->>UI: 모달 닫기 및 갱신 알림
            deactivate Modal
            
            UI->>UI: renderUserList()
            UI-->>Admin: 사용자 목록 렌더링 (변경 반영)
            deactivate UI
        end
    end