sequenceDiagram
    autonumber
    actor Admin as 관리자
    participant UI as : UserManagementUI
    participant Modal as : ConfirmModalUI
    participant Service as : UserPenaltyService
    participant UserRepo as : UserRepository
    participant User as : User
    participant Penalty as : Penalty
    participant PenRepo as : PenaltyRepository

    Admin->>UI: '권한 복구(해제)' 버튼 클릭 (userId, penaltyId 전달)
    activate UI
    UI->>Modal: open("권한을 복구하시겠습니까?")
    activate Modal
    Modal-->>Admin: 확인 모달창 렌더링
    
    Admin->>Modal: '확인(복구)' 버튼 클릭
    Modal->>Service: releasePenalty(userId, penaltyId)
    activate Service
    
    %% 1. 데이터 조회
    Service->>UserRepo: findById(userId)
    activate UserRepo
    UserRepo-->>Service: User 객체 반환
    deactivate UserRepo
    
    Service->>PenRepo: findById(penaltyId)
    activate PenRepo
    PenRepo-->>Service: Penalty 객체 반환
    deactivate PenRepo
    
    %% 2. 비즈니스 로직 처리 (상태 복구)
    alt [DB 연결 오류 시 (Extension 4a)]
        Service-->>Modal: 시스템 오류 예외 반환
        Modal-->>Admin: 메시지 출력 ("시스템 오류로 권한 복구에 실패했습니다")
        
    else [정상 복구 시 (Main Success)]
        %% 사용자 상태 정상화
        Service->>User: restoreStatus()
        activate User
        User-->>Service: 상태 '정상'으로 변경 완료
        deactivate User
        
        %% 제재 내역 만료 처리
        Service->>Penalty: expire()
        activate Penalty
        Penalty-->>Service: 제재 '종료' 처리 완료
        deactivate Penalty
        
        Service->>PenRepo: save(penalty)
        activate PenRepo
        PenRepo-->>Service: 저장 완료
        deactivate PenRepo
        
        Service-->>Modal: 복구 완료 반환
        deactivate Service
        
        Modal->>Modal: displaySuccess()
        Modal-->>UI: 모달 닫기 및 갱신 알림
        deactivate Modal
        
        UI->>UI: renderUserList()
        UI-->>Admin: 사용자 목록 렌더링 (정상 상태 반영)
        deactivate UI
    end