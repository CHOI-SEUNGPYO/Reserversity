sequenceDiagram
    autonumber
    actor Admin as 관리자
    participant UI as : ReservationUI
    participant Modal as : ReservationModalUI
    participant Service as : ReservationService
    participant UserRepo as : UserRepository
    participant RsvRepo as : ReservationRepository
    participant Entity as : Reservation

    Admin->>UI: '+ 예약 등록' 클릭
    activate UI
    UI->>Modal: open()
    activate Modal
    Modal-->>Admin: 예약 입력 모달창 렌더링
    
    Admin->>Modal: 예약 정보 입력 (자원, 예약자, 시간 등)
    Admin->>Modal: '저장' 버튼 클릭 (submit)
    
    %% 1차 검증: UI 계층 (필수값 누락)
    alt [필수 값 누락 시 (Extension 3b)]
        Modal-->>Admin: 입력 필드 강조 및 경고 ("필수 항목을 모두 입력해 주세요")
        
    else [UI 검증 정상 통과 시]
        Modal->>Service: createReservation(ReservationDto)
        activate Service
        
        %% 2차 검증: Include(사용자 제재 확인)
        Service->>UserRepo: findById(userId)
        activate UserRepo
        UserRepo-->>Service: User 객체 반환
        deactivate UserRepo
        
        alt [사용자 제재 상태일 경우 (Extension 4a)]
            Service-->>Modal: 예약 권한 제한 예외 반환
            Modal-->>Admin: 경고 출력 ("현재 예약 권한이 제한된 상태입니다")
            
        else [시간 충돌 확인 (Step 5)]
            Service->>RsvRepo: existsConflict(resourceId, startTime, endTime)
            activate RsvRepo
            RsvRepo-->>Service: boolean 결과 반환
            deactivate RsvRepo
            
            alt [시간 충돌 발생 시 (Extension 5a)]
                Service-->>Modal: 예약 시간 충돌 예외 반환
                Modal-->>Admin: 경고 출력 ("이미 해당 자원의 예약이 존재합니다")
                
            else [DB 연결 오류 시 (Extension 6a)]
                Service-->>Modal: 시스템 오류 예외 반환
                Modal-->>Admin: 메시지 출력 ("시스템 오류로 예약 등록에 실패했습니다")
                
            else [최종 성공 (Main Success)]
                Service->>Entity: create(reservationData)
                activate Entity
                Entity-->>Service: Reservation 객체 반환
                deactivate Entity
                
                Service->>RsvRepo: save(reservation)
                activate RsvRepo
                RsvRepo-->>Service: 저장된 객체 반환
                deactivate RsvRepo
                
                Service-->>Modal: 생성된 예약 ID 반환
                deactivate Service
                
                Modal->>Modal: displaySuccess()
                Modal-->>UI: 모달 닫기 및 갱신 알림
                deactivate Modal
                
                UI->>UI: renderReservationList()
                UI-->>Admin: 예약 목록/캘린더 렌더링
                deactivate UI
            end
        end
    end